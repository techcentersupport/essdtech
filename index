<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESSD Technology Department | Excelsior Springs School District</title>
    <style>
        :root {
            --primary-color: #003366; /* District Blue */
            --accent-color: #d9534f;  /* Action Red */
            --light-bg: #f8f9fa;
            --dark-text: #212529;
            --card-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            color: var(--dark-text);
            background-color: #f0f2f5;
            line-height: 1.6;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            background-color: var(--primary-color);
            color: white;
            padding: 2rem 1rem;
            text-align: center;
        }

        header h1 {
            font-size: 2.2rem;
            margin-bottom: 0.5rem;
        }

        header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .container {
            max-width: 1000px;
            margin: 2rem auto;
            padding: 0 1rem;
            flex: 1;
        }

        .hero-card {
            background: white;
            border-radius: 8px;
            padding: 2.5rem;
            text-align: center;
            box-shadow: var(--card-shadow);
            margin-bottom: 2rem;
            border-top: 5px solid var(--primary-color);
        }

        .hero-card h2 {
            margin-bottom: 1rem;
            color: var(--primary-color);
        }

        .cta-button {
            display: inline-block;
            background-color: var(--accent-color);
            color: white;
            font-size: 1.25rem;
            font-weight: bold;
            padding: 0.8rem 2rem;
            border-radius: 6px;
            text-decoration: none;
            transition: background-color 0.2s ease;
            margin-top: 1rem;
        }

        .cta-button:hover {
            background-color: #c9302c;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: var(--card-shadow);
        }

        .card h3 {
            color: var(--primary-color);
            margin-bottom: 0.75rem;
            border-bottom: 2px solid var(--light-bg);
            padding-bottom: 0.5rem;
        }

        .contact-list {
            list-style: none;
        }

        .contact-list li {
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
        }

        .contact-list a {
            color: var(--primary-color);
            text-decoration: none;
        }

        .contact-list a:hover {
            text-decoration: underline;
        }

        footer {
            background-color: #e9ecef;
            text-align: center;
            padding: 1.5rem;
            font-size: 0.9rem;
            color: #6c757d;
            margin-top: 2rem;
        }

        footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <header>
        <h1>Excelsior Springs School District</h1>
        <p>Technology Department</p>
    </header>

    <div class="container">
        
        <!-- Quick Help Section -->
        <section class="hero-card">
            <h2>Need Technical Support?</h2>
            <p>Submit or track a support ticket through our official Help Desk portal.</p>
            <a href="https://excelsiorssd.gethelphss.com/UI/dashboard" class="cta-button" target="_blank" rel="noopener">
                Access Technology Help Desk &rarr;
            </a>
        </section>

        <!-- Details Grid -->
        <div class="grid">
            
            <!-- Contact Info -->
            <div class="card">
                <h3>Contact & Location</h3>
                <ul class="contact-list">
                    <li>📍 <strong>Address:</strong>&nbsp;113 Line St, Excelsior Springs, MO 64024</li>
                    <li>📞 <strong>Phone:</strong>&nbsp;<a href="tel:8166301280">816-630-1280</a></li>
                    <li>🌐 <strong>District Portal:</strong>&nbsp;<a href="https://essd40.org" target="_blank" rel="noopener">essd40.org</a></li>
                </ul>
            </div>

            <!-- Quick Links / Hours -->
            <div class="card">
                <h3>Services & Resources</h3>
                <p>We support staff and student devices, network infrastructure, classroom technology, and software access across ESSD #40.</p>
            </div>

        </div>

    </div>

    <footer>
        <p>&copy; Excelsior Springs School District #40 | <a href="https://essd40.org">essd40.org</a></p>
    </footer>

</body>
</html>
